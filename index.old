<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Dummymall | Quick Commerce Store</title>

<meta name="description" content="Dummymall Official Website - Quick Commerce Store with Fast Delivery, COD, Premium Gift Items, Cosmetics & Daily Nee

<style>
{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
scroll-behavior:smooth;
}

body{
background:#f5f5f5;
color:#222;
}

header{
background:#d40000;
color:#fff;
display:flex;
justify-content:space-between;
align-items:center;
padding:15px 8%;
position:sticky;
top:0;
z-index:999;
box-shadow:0 5px 15px rgba(0,0,0,.2);
}

.logo{
display:flex;
align-items:center;
gap:10px;
}

.logo img{
width:55px;
height:55px;
border-radius:50%;
}

nav a{
color:#fff;
text-decoration:none;
margin-left:20px;
font-weight:bold;
transition:.3s;
}

nav a:hover{
color:#ffd700;
}

.hero{
background:linear-gradient(135deg,#ff3b3b,#ff9900);
color:#fff;
padding:70px 8%;
text-align:center;
}

.hero h1{
font-size:45px;
margin-bottom:15px;
}

.hero p{
font-size:20px;
margin-bottom:30px;
}

.buttons{
display:flex;
justify-content:center;
flex-wrap:wrap;
gap:15px;
}

.btn{
padding:14px 28px;
border-radius:50px;
text-decoration:none;
color:#fff;
font-weight:bold;
transition:.3s;
}

.red{
background:#e60000;
}

.blue{
background:#0066ff;
}

.green{
background:#00aa55;
}

.btn:hover{
transform:translateY(-4px);
box-shadow:0 8px 20px rgba(0,0,0,.25);
}

section{
padding:60px 8%;
}

section h2{
text-align:center;
font-size:35px;
margin-bottom:20px;
color:#d40000;
}

section p{
text-align:center;
line-height:28px;
}

.features{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
gap:20px;
margin-top:35px;
}

.card{
background:#fff;
padding:25px;
border-radius:15px;
text-align:center;
box-shadow:0 5px 15px rgba(0,0,0,.1);
transition:.3s;
}

.card:hover{
transform:translateY(-8px);
}

.card i{
font-size:45px;
color:#d40000;
margin-bottom:15px;
}

.download{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:25px;
}

.app{
background:#fff;
padding:30px;
border-radius:18px;
text-align:center;
box-shadow:0 5px 15px rgba(0,0,0,.1);
}

.app h3{
margin-bottom:10px;
}

.app p{
margin-bottom:20px;
}

.app a{
background:#d40000;
padding:12px 25px;
color:#fff;
text-decoration:none;
border-radius:30px;
display:inline-block;
}

.coupon{
background:#d40000;
color:#fff;
text-align:center;
padding:70px 20px;
}

.coupon h1{
font-size:55px;
letter-spacing:5px;
margin:15px 0;
}

#owner{
background:#fff;
}

#owner p{
margin:12px 0;
font-size:18px;
}

footer{
background:#111;
color:#fff;
padding:45px 20px;
text-align:center;
}

.social{
margin:20px 0;
}

.social a{
display:inline-block;
width:48px;
height:48px;
line-height:48px;
font-size:22px;
background:#d40000;
color:#fff;
border-radius:50%;
margin:8px;
transition:.3s;
}

.social a:hover{
transform:scale(1.1);
}

.links{
margin:20px 0;
}

.links a{
color:#fff;
text-decoration:none;
margin:0 12px;
}

.links a:hover{
color:#ffd700;
}

@media(max-width:768px){

header{
flex-direction:column;
gap:15px;
}

nav{
display:flex;
flex-wrap:wrap;
justify-content:center;
}

.hero h1{
font-size:32px;
}

.hero p{
font-size:17px;
}

section h2{
font-size:28px;
}

.coupon h1{
font-size:38px;
}

}
  nav a.active{
color:#ffd700;
}

html{
scroll-behavior:smooth;
}
  
  

</style>
<link rel="icon" href="logo.png">

</head>

<body>

